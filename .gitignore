# ── Generated experiment artifacts (regenerated by the pipeline) ────────────
latest/
results/
vocab_output/
processed/
wandb/
logs/
gt_cache/
.audit_vocab/

# NOTE: analysis/ is SOURCE CODE (plotting, tables, probe, run_analysis) and is
# intentionally NOT ignored. If you want to ignore only the generated plots,
# they live under results/plots/ which is already covered by results/ above.

# ── Local artifact validation / report outputs (never commit) ───────────────
_validate_vocab/
_validation_results/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# ── Model / data blobs that shouldn't be in git ─────────────────────────────
*.pt
*.pth
*.pickle
*.ckpt
# Whole data folder (datasets are downloaded/regenerated, not versioned).
data/

# ── Design retrospective (report/deck + exported source chats; not for GitHub) ─
reports/

